<view class="page">
  <view class="search-bar" bindtap="goSearch">
    <text class="search-placeholder">🔍 搜索文章标题...</text>
    <text class="search-arrow">▾</text>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中…</view>

  <block wx:else>
    <!-- 模块1 热门话题 -->
    <view class="section" wx:if="{{topics.length}}">
      <view class="section-header">
        <text class="section-title">热门话题</text>
      </view>
      <scroll-view scroll-x class="topic-scroll" enable-flex>
        <topic-card
          wx:for="{{topics}}"
          wx:key="id"
          item="{{item}}"
          bind:tapcard="onTopicCard"
          bind:tapjoin="onTopicJoin"
        />
      </scroll-view>
      <view class="section-link" bindtap="goTopics">查看全部话题 →</view>
    </view>

    <!-- 模块2 24小时热榜 -->
    <view class="section" wx:if="{{hotItems.length}}">
      <view class="section-header">
        <text class="section-title">24小时热榜</text>
      </view>
      <view
        wx:for="{{hotItems}}"
        wx:key="id"
        class="hot-item"
        data-id="{{item.id}}"
        bindtap="goArticle"
      >
        <text class="hot-rank">{{item.rank <= 3 ? ['🥇','🥈','🥉'][item.rank-1] : item.rank}}</text>
        <view class="hot-body">
          <text class="hot-title">{{item.title}}</text>
          <text class="hot-meta">{{item.authorNickname}} · {{item.viewCount}}阅读 · {{item.likeCount}}点赞</text>
        </view>
      </view>
      <view class="section-link" bindtap="goHotRank">查看完整榜单 →</view>
    </view>

    <!-- 模块3 精选新文 -->
    <view class="section" wx:if="{{featured.length}}">
      <view class="section-header">
        <text class="section-title">精选新文</text>
      </view>
      <view
        wx:for="{{featured}}"
        wx:key="id"
        class="featured-card"
        data-id="{{item.id}}"
        bindtap="goArticle"
      >
        <view class="featured-cover" wx:if="{{item.coverUrl}}">
          <image src="{{item.coverUrl}}" mode="aspectFill" />
        </view>
        <view class="featured-body">
          <text class="featured-title">{{item.title}}</text>
          <text class="featured-meta">{{item.authorNickname}} · {{item.categoryName}}</text>
        </view>
      </view>
      <view class="section-link" bindtap="goFeaturedList">查看更多新文 →</view>
    </view>

    <!-- 模块4 按分类浏览 -->
    <view class="section" wx:for="{{categories}}" wx:key="id">
      <view class="section-header">
        <text class="section-title">▌{{item.name}}</text>
      </view>
      <view
        wx:for="{{item.articles}}"
        wx:for-item="article"
        wx:key="id"
        class="category-article"
        data-id="{{article.id}}"
        bindtap="goArticle"
      >
        <text>· {{article.title}}</text>
      </view>
      <view class="section-link" data-id="{{item.id}}" bindtap="goCategories">查看更多{{item.name}} →</view>
    </view>
    <view class="section-link main" bindtap="goCategories">进入全部分类 →</view>
  </block>
</view>
